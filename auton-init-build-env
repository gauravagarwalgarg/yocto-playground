#!/bin/bash
# =============================================================================
# Auton Build Environment Setup
# =============================================================================
#
# Usage:
#   source auton-init-build-env                  # Interactive machine selection
#   source auton-init-build-env beaglebone-black # Direct machine selection
#   source auton-init-build-env raspberrypi5
#   source auton-init-build-env qemu-arm
#   source auton-init-build-env qemu-arm64
#
# This script:
#   1. Sources poky's oe-init-build-env
#   2. Configures local.conf and bblayers.conf for the selected machine
#   3. Sets up the Auton distro with Linux 6.12 LTS
#
# =============================================================================

# Ensure this script is sourced, not executed
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "ERROR: This script must be sourced, not executed."
    echo "Usage: source ${BASH_SOURCE[0]} [machine]"
    exit 1
fi

# Determine the root of this repo
AUTON_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Available machines
declare -A AUTON_MACHINES
AUTON_MACHINES=(
    ["beaglebone-black"]="TI AM335x Cortex-A8 (ARMv7)"
    ["raspberrypi5"]="BCM2712 Cortex-A76 (ARMv8.2-A)"
    ["qemu-arm"]="QEMU ARM 32-bit (Cortex-A15, vexpress)"
    ["qemu-arm64"]="QEMU AArch64 (Cortex-A57)"
)

# Parse machine argument or prompt
AUTON_MACHINE="${1:-}"

if [ -z "$AUTON_MACHINE" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║           Auton Embedded Linux - Build Setup                ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "  Select a target machine:"
    echo ""
    echo "  1) beaglebone-black   - ${AUTON_MACHINES[beaglebone-black]}"
    echo "  2) raspberrypi5       - ${AUTON_MACHINES[raspberrypi5]}"
    echo "  3) qemu-arm           - ${AUTON_MACHINES[qemu-arm]}"
    echo "  4) qemu-arm64         - ${AUTON_MACHINES[qemu-arm64]}"
    echo ""
    read -p "  Enter choice [1-4]: " choice

    case "$choice" in
        1) AUTON_MACHINE="beaglebone-black" ;;
        2) AUTON_MACHINE="raspberrypi5" ;;
        3) AUTON_MACHINE="qemu-arm" ;;
        4) AUTON_MACHINE="qemu-arm64" ;;
        *)
            echo "  Invalid choice. Defaulting to qemu-arm64."
            AUTON_MACHINE="qemu-arm64"
            ;;
    esac
fi

# Validate machine
if [ -z "${AUTON_MACHINES[$AUTON_MACHINE]+x}" ]; then
    echo "ERROR: Unknown machine '$AUTON_MACHINE'"
    echo "Available: ${!AUTON_MACHINES[*]}"
    return 1
fi

echo ""
echo "  Machine: $AUTON_MACHINE (${AUTON_MACHINES[$AUTON_MACHINE]})"
echo ""

# Determine paths
AUTON_SOURCES="${AUTON_ROOT}/sources"
AUTON_POKY="${AUTON_SOURCES}/poky"
AUTON_BUILDDIR="${AUTON_ROOT}/build/${AUTON_MACHINE}"

# Check if poky exists (repo sync must have been done)
if [ ! -d "$AUTON_POKY" ]; then
    echo "ERROR: Poky not found at $AUTON_POKY"
    echo ""
    echo "Run repo sync first:"
    echo "  repo init -u https://github.com/GauravAgarwalGarg/MyYoctoPlayground.git \\"
    echo "      -m manifests/${AUTON_MACHINE}.xml -b main"
    echo "  repo sync"
    return 1
fi

# Source poky's oe-init-build-env
source "${AUTON_POKY}/oe-init-build-env" "$AUTON_BUILDDIR"

# =============================================================================
# Configure local.conf
# =============================================================================

_auton_write_local_conf() {
    local machine="$1"
    local conf_file="${AUTON_BUILDDIR}/conf/local.conf"

    # Don't overwrite if already configured for this machine
    if grep -q "^MACHINE.*=.*\"${machine}\"" "$conf_file" 2>/dev/null; then
        return
    fi

    cat > "$conf_file" << EOF
# =============================================================================
# Auton Build Configuration - ${machine}
# Generated by: source auton-init-build-env ${machine}
# =============================================================================

MACHINE = "${machine}"
DISTRO = "auton"

# Shared download and sstate directories
DL_DIR = "${AUTON_ROOT}/downloads"
SSTATE_DIR = "${AUTON_ROOT}/sstate-cache"

# Package management
PACKAGE_CLASSES = "package_ipk"

# Development convenience
EXTRA_IMAGE_FEATURES ?= "debug-tweaks"

# Parallelism
BB_NUMBER_THREADS = "\${@oe.utils.cpu_count()}"
PARALLEL_MAKE = "-j \${@oe.utils.cpu_count()}"

# Accept commercial licenses
LICENSE_FLAGS_ACCEPTED = "commercial"

# Disk space monitoring
BB_DISKMON_DIRS ??= "\\
    STOPTASKS,\${TMPDIR},1G,100K \\
    STOPTASKS,\${DL_DIR},1G,100K \\
    STOPTASKS,\${SSTATE_DIR},1G,100K \\
    HALT,\${TMPDIR},100M,1K \\
    HALT,\${DL_DIR},100M,1K \\
    HALT,\${SSTATE_DIR},100M,1K \\
"
EOF

    # Machine-specific additions
    case "$machine" in
        raspberrypi5)
            cat >> "$conf_file" << 'EOF'

# Raspberry Pi 5 specific
RPI_USE_U_BOOT = "1"
ENABLE_UART = "1"
DISABLE_OVERSCAN = "1"
EOF
            ;;
        qemu-arm|qemu-arm64)
            cat >> "$conf_file" << 'EOF'

# QEMU specific - enable graphics and networking for runqemu
QEMU_USE_KVM = "1"
QB_MEM = "-m 1024"
EOF
            ;;
    esac
}

# =============================================================================
# Configure bblayers.conf
# =============================================================================

_auton_write_bblayers_conf() {
    local machine="$1"
    local conf_file="${AUTON_BUILDDIR}/conf/bblayers.conf"

    # Common layers
    local layers="
  ${AUTON_SOURCES}/poky/meta \\\\
  ${AUTON_SOURCES}/poky/meta-poky \\\\
  ${AUTON_SOURCES}/poky/meta-yocto-bsp \\\\
  ${AUTON_SOURCES}/meta-openembedded/meta-oe \\\\
  ${AUTON_SOURCES}/meta-openembedded/meta-networking \\\\
  ${AUTON_SOURCES}/meta-openembedded/meta-python \\\\"

    # Machine-specific BSP layers
    case "$machine" in
        beaglebone-black)
            layers="${layers}
  ${AUTON_SOURCES}/meta-ti/meta-ti-bsp \\\\"
            ;;
        raspberrypi5)
            layers="${layers}
  ${AUTON_SOURCES}/meta-raspberrypi \\\\"
            ;;
        qemu-arm|qemu-arm64)
            # No extra BSP layer needed for QEMU
            ;;
    esac

    # Always add meta-auton last (highest priority)
    layers="${layers}
  ${AUTON_ROOT}/meta-auton \\\\"

    cat > "$conf_file" << EOF
# =============================================================================
# Auton Layer Configuration - ${machine}
# Generated by: source auton-init-build-env ${machine}
# =============================================================================

POKY_BBLAYERS_CONF_VERSION = "2"

BBPATH = "\${TOPDIR}"
BBFILES ?= ""

BBLAYERS ?= " \\
${layers}
"
EOF
}

# =============================================================================
# Write configs
# =============================================================================

mkdir -p "${AUTON_BUILDDIR}/conf"
_auton_write_local_conf "$AUTON_MACHINE"
_auton_write_bblayers_conf "$AUTON_MACHINE"

# Cleanup helper functions
unset -f _auton_write_local_conf
unset -f _auton_write_bblayers_conf

# =============================================================================
# Summary
# =============================================================================

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  Auton build environment ready                             ║"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║  Machine : $AUTON_MACHINE"
echo "║  Distro  : auton (Linux 6.12 LTS, systemd)"
echo "║  Build   : ${AUTON_BUILDDIR}"
echo "║  Layers  : meta-auton + poky + meta-oe"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║  Build commands:                                           ║"
echo "║    bitbake auton-image-minimal    # Base image             ║"
echo "║    bitbake auton-image-dev        # Dev image              ║"
if [[ "$AUTON_MACHINE" == qemu-* ]]; then
echo "║    runqemu $AUTON_MACHINE         # Run in QEMU           ║"
fi
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
