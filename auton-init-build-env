#!/bin/bash
# =============================================================================
# Auton Build Environment Setup
# =============================================================================
#
# Usage:
#   source auton-init-build-env                  # Interactive selection
#   source auton-init-build-env qemu-arm64       # Direct: QEMU AArch64
#   source auton-init-build-env beaglebone-black # Direct: BeagleBone Black
#   source auton-init-build-env raspberrypi5     # Direct: Raspberry Pi 5
#   source auton-init-build-env all              # Multiconfig: all machines
#
# Supports Yocto Scarthgap LTS baseline.
# =============================================================================

# Must be sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "ERROR: This script must be sourced."
    echo "Usage: source auton-init-build-env [machine|all]"
    exit 1
fi

# --- Detect paths ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect workspace root: are we inside sources/meta-auton-repo/ ?
if [ -d "${SCRIPT_DIR}/../../poky" ]; then
    WORKSPACE="$(cd "${SCRIPT_DIR}/../.." && pwd)"
elif [ -d "${SCRIPT_DIR}/sources/poky" ]; then
    WORKSPACE="$SCRIPT_DIR"
else
    echo "ERROR: Cannot find poky. Expected at:"
    echo "  ${SCRIPT_DIR}/../../poky  (repo-synced workspace)"
    echo "  ${SCRIPT_DIR}/sources/poky (standalone)"
    echo ""
    echo "Run repo sync first:"
    echo "  repo init -u https://github.com/GauravAgarwalGarg/MyYoctoPlayground.git -m manifests/qemu.xml -b main"
    echo "  repo sync"
    return 1
fi

AUTON_LAYER="${SCRIPT_DIR}/meta-auton"
SOURCES="${WORKSPACE}/sources"
POKY="${SOURCES}/poky"
BUILDDIR="${WORKSPACE}/build"

# --- Machine selection ---
MACHINE="${1:-}"
VALID_MACHINES="qemu-arm64 beaglebone-black raspberrypi5 all"

if [ -z "$MACHINE" ]; then
    echo ""
    echo "  Select target machine:"
    echo "    1) qemu-arm64        QEMU AArch64 (Cortex-A57)"
    echo "    2) beaglebone-black  TI AM335x (Cortex-A8)"
    echo "    3) raspberrypi5      BCM2712 (Cortex-A76)"
    echo "    4) all               Multiconfig (all machines)"
    echo ""
    read -p "  Choice [1-4]: " choice
    case "$choice" in
        1) MACHINE="qemu-arm64" ;;
        2) MACHINE="beaglebone-black" ;;
        3) MACHINE="raspberrypi5" ;;
        4) MACHINE="all" ;;
        *) MACHINE="qemu-arm64" ;;
    esac
fi

echo ""
echo "  Machine:   $MACHINE"
echo "  Workspace: $WORKSPACE"
echo ""

# --- Source poky ---
source "${POKY}/oe-init-build-env" "$BUILDDIR"

# --- Generate local.conf ---
LOCALCONF="${BUILDDIR}/conf/local.conf"
if ! grep -q "DISTRO.*auton" "$LOCALCONF" 2>/dev/null; then
    cat > "$LOCALCONF" << EOF
# =============================================================================
# Auton Build - Generated by auton-init-build-env
# Machine: $MACHINE | Distro: auton | Yocto: Scarthgap LTS
# =============================================================================

DISTRO = "auton"

# Default machine (used for single-machine builds)
MACHINE = "${MACHINE}"

# Multiconfig: build all machines from one workspace
# Usage: bitbake mc:qemu-arm64:auton-image-minimal
#        bitbake mc:beaglebone-black:auton-image-minimal
#        bitbake mc:raspberrypi5:auton-image-minimal
BBMULTICONFIG = "qemu-arm64 beaglebone-black raspberrypi5"

# Shared directories (saves disk across multiconfig builds)
DL_DIR = "${WORKSPACE}/downloads"
SSTATE_DIR = "${WORKSPACE}/sstate-cache"

# Parallelism
BB_NUMBER_THREADS = "\${@oe.utils.cpu_count()}"
PARALLEL_MAKE = "-j \${@oe.utils.cpu_count()}"

# Development
EXTRA_IMAGE_FEATURES ?= "debug-tweaks"
LICENSE_FLAGS_ACCEPTED = "commercial"

# Disk monitoring
BB_DISKMON_DIRS ??= "\\
    STOPTASKS,\${TMPDIR},1G,100K \\
    STOPTASKS,\${DL_DIR},1G,100K \\
    HALT,\${TMPDIR},100M,1K \\
"
EOF
fi

# --- Generate bblayers.conf ---
BBLAYERS="${BUILDDIR}/conf/bblayers.conf"
if ! grep -q "meta-auton" "$BBLAYERS" 2>/dev/null; then
    cat > "$BBLAYERS" << EOF
# =============================================================================
# Auton Layers - All BSP layers included for multiconfig support
# =============================================================================
POKY_BBLAYERS_CONF_VERSION = "2"
BBPATH = "\${TOPDIR}"
BBFILES ?= ""

BBLAYERS ?= " \\
  ${SOURCES}/poky/meta \\
  ${SOURCES}/poky/meta-poky \\
  ${SOURCES}/poky/meta-yocto-bsp \\
  ${SOURCES}/meta-openembedded/meta-oe \\
  ${SOURCES}/meta-openembedded/meta-networking \\
  ${SOURCES}/meta-openembedded/meta-python \\
  ${AUTON_LAYER} \\
"

# BSP layers (add when synced with respective manifests)
# Uncomment after syncing with beaglebone-black.xml or raspberrypi5.xml:
# BBLAYERS += " ${SOURCES}/meta-ti/meta-ti-bsp"
# BBLAYERS += " ${SOURCES}/meta-raspberrypi"
EOF

    # Auto-detect and add BSP layers if they exist
    if [ -d "${SOURCES}/meta-ti/meta-ti-bsp" ]; then
        echo "BBLAYERS += \" ${SOURCES}/meta-ti/meta-ti-bsp\"" >> "$BBLAYERS"
    fi
    if [ -d "${SOURCES}/meta-raspberrypi" ]; then
        echo "BBLAYERS += \" ${SOURCES}/meta-raspberrypi\"" >> "$BBLAYERS"
    fi
fi

# --- Copy multiconfig files ---
mkdir -p "${BUILDDIR}/conf/multiconfig"
for mc in qemu-arm64 beaglebone-black raspberrypi5; do
    MC_SRC="${AUTON_LAYER}/conf/multiconfig/${mc}.conf"
    MC_DST="${BUILDDIR}/conf/multiconfig/${mc}.conf"
    if [ -f "$MC_SRC" ] && [ ! -f "$MC_DST" ]; then
        cp "$MC_SRC" "$MC_DST"
    fi
done

# --- Summary ---
echo ""
echo "==============================================================="
echo "  Auton build environment ready"
echo "==============================================================="
echo "  Workspace : $WORKSPACE"
echo "  Build dir : $BUILDDIR"
echo "  Distro    : auton (Scarthgap LTS)"
echo "  Machine   : $MACHINE"
echo ""
echo "  Build commands:"
if [ "$MACHINE" = "all" ]; then
    echo "    bitbake mc:qemu-arm64:auton-image-minimal"
    echo "    bitbake mc:beaglebone-black:auton-image-minimal"
    echo "    bitbake mc:raspberrypi5:auton-image-minimal"
else
    echo "    bitbake auton-image-minimal"
    echo "    bitbake auton-image-dev"
fi
echo ""
echo "  Run QEMU:"
echo "    runqemu qemu-arm64 nographic slirp"
echo "==============================================================="
