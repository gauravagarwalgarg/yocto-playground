#!/bin/bash
# =============================================================================
# Auton Build Environment Setup
# =============================================================================
#
# Usage:
#   source auton-init-build-env qemu-arm64       # QEMU AArch64
#   source auton-init-build-env qemux86-64       # QEMU x86-64 (stock, fastest)
#   source auton-init-build-env beaglebone-black # BeagleBone Black
#   source auton-init-build-env raspberrypi5     # Raspberry Pi 5
#   source auton-init-build-env                  # Interactive selection
#
# Builds ONE machine at a time. No multiconfig complexity.
# Yocto Scarthgap LTS baseline.
# =============================================================================

# Must be sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "ERROR: This script must be sourced."
    echo "Usage: source auton-init-build-env [machine]"
    exit 1
fi

# --- Detect paths ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect workspace root
if [ -d "${SCRIPT_DIR}/../poky" ]; then
    # Inside sources/meta-auton-repo/ (repo-synced workspace)
    WORKSPACE="$(cd "${SCRIPT_DIR}/../.." && pwd)"
elif [ -d "${SCRIPT_DIR}/sources/poky" ]; then
    # Standalone (script at workspace root)
    WORKSPACE="$SCRIPT_DIR"
else
    echo "ERROR: Cannot find poky."
    echo "  Expected: ${SCRIPT_DIR}/../poky (repo-synced)"
    echo "  Or: ${SCRIPT_DIR}/sources/poky (standalone)"
    echo ""
    echo "Run: ./scripts/02-repo-sync.sh"
    return 1
fi

AUTON_LAYER="${SCRIPT_DIR}/meta-auton"
SOURCES="${WORKSPACE}/sources"
POKY="${SOURCES}/poky"

# --- Machine selection ---
MACHINE="${1:-}"

if [ -z "$MACHINE" ]; then
    echo ""
    echo "  Select target:"
    echo "    1) qemux86-64        QEMU x86-64 (stock, fastest build)"
    echo "    2) qemu-arm64        QEMU AArch64 (Cortex-A57)"
    echo "    3) beaglebone-black  TI AM335x (Cortex-A8)"
    echo "    4) raspberrypi5      BCM2712 (Cortex-A76)"
    echo ""
    read -p "  Choice [1-4]: " choice
    case "$choice" in
        1) MACHINE="qemux86-64" ;;
        2) MACHINE="qemu-arm64" ;;
        3) MACHINE="beaglebone-black" ;;
        4) MACHINE="raspberrypi5" ;;
        *) MACHINE="qemux86-64" ;;
    esac
fi

echo ""
echo "  Machine:   $MACHINE"
echo "  Workspace: $WORKSPACE"

# --- Determine distro and kernel ---
# Stock QEMU machines use poky distro + linux-yocto (guaranteed to work)
# Custom/hardware machines use auton distro + linux-auton
case "$MACHINE" in
    qemux86-64|qemux86)
        DISTRO="poky"
        KERNEL_PROVIDER="linux-yocto"
        ;;
    qemu-arm64|qemu-arm)
        DISTRO="auton"
        KERNEL_PROVIDER="linux-yocto"
        ;;
    beaglebone-black|raspberrypi5)
        DISTRO="auton"
        KERNEL_PROVIDER="linux-yocto"
        ;;
esac

# --- Source poky ---
BUILDDIR="${WORKSPACE}/build"
source "${POKY}/oe-init-build-env" "$BUILDDIR"

# --- Generate local.conf (only if not already configured for this machine) ---
LOCALCONF="${BUILDDIR}/conf/local.conf"
if ! grep -q "^MACHINE.*\"${MACHINE}\"" "$LOCALCONF" 2>/dev/null; then
    cat > "$LOCALCONF" << EOF
# =============================================================================
# Auton Build - Machine: ${MACHINE}
# Generated by: source auton-init-build-env ${MACHINE}
# Yocto: Scarthgap LTS
# =============================================================================

MACHINE = "${MACHINE}"
DISTRO = "${DISTRO}"

# Kernel
PREFERRED_PROVIDER_virtual/kernel:forcevariable = "${KERNEL_PROVIDER}"

# Image formats (ext4 for QEMU runqemu, wic for SD card flash)
IMAGE_FSTYPES += "ext4 tar.xz wic wic.bmap"

# Shared directories
DL_DIR = "${WORKSPACE}/downloads"
SSTATE_DIR = "${WORKSPACE}/sstate-cache"

# Parallelism
BB_NUMBER_THREADS = "\${@oe.utils.cpu_count()}"
PARALLEL_MAKE = "-j \${@oe.utils.cpu_count()}"

# Development
EXTRA_IMAGE_FEATURES = "debug-tweaks"
LICENSE_FLAGS_ACCEPTED = "commercial"

# Disk monitoring
BB_DISKMON_DIRS ??= "\\
    STOPTASKS,\${TMPDIR},1G,100K \\
    STOPTASKS,\${DL_DIR},1G,100K \\
    HALT,\${TMPDIR},100M,1K \\
"
EOF
fi

# --- Generate bblayers.conf (machine-specific layers only) ---
BBLAYERS="${BUILDDIR}/conf/bblayers.conf"
if ! grep -q "meta-auton" "$BBLAYERS" 2>/dev/null; then
    cat > "$BBLAYERS" << EOF
# Auton Layers - Machine: ${MACHINE}
POKY_BBLAYERS_CONF_VERSION = "2"
BBPATH = "\${TOPDIR}"
BBFILES ?= ""

BBLAYERS ?= " \\
  ${SOURCES}/poky/meta \\
  ${SOURCES}/poky/meta-poky \\
  ${SOURCES}/poky/meta-yocto-bsp \\
  ${SOURCES}/meta-openembedded/meta-oe \\
  ${SOURCES}/meta-openembedded/meta-networking \\
  ${SOURCES}/meta-openembedded/meta-python \\
  ${AUTON_LAYER} \\
"
EOF

    # Add machine-specific BSP layers
    case "$MACHINE" in
        beaglebone-black)
            [ -d "${SOURCES}/meta-arm/meta-arm" ] && echo "BBLAYERS += \" ${SOURCES}/meta-arm/meta-arm\"" >> "$BBLAYERS"
            [ -d "${SOURCES}/meta-ti/meta-ti-bsp" ] && echo "BBLAYERS += \" ${SOURCES}/meta-ti/meta-ti-bsp\"" >> "$BBLAYERS"
            ;;
        raspberrypi5)
            [ -d "${SOURCES}/meta-raspberrypi" ] && echo "BBLAYERS += \" ${SOURCES}/meta-raspberrypi\"" >> "$BBLAYERS"
            ;;
    esac
fi

# --- Summary ---
echo ""
echo "==============================================================="
echo "  Build environment ready"
echo "==============================================================="
echo "  Machine  : $MACHINE"
echo "  Distro   : $DISTRO"
echo "  Kernel   : $KERNEL_PROVIDER"
echo "  Build    : $BUILDDIR"
echo ""
echo "  Commands:"
echo "    bitbake core-image-minimal      # Stock minimal image"
echo "    bitbake auton-image-minimal     # Auton image (custom)"
echo ""
if [[ "$MACHINE" == qemu* ]]; then
    echo "  Run QEMU:"
    echo "    runqemu $MACHINE nographic slirp"
fi
echo "==============================================================="
