<?xml version="1.0" encoding="UTF-8"?>
<!--
  QEMU manifest: minimal layers for local WSL/CI builds.
  No BSP layer needed - QEMU machines are defined in meta-auton.
-->
<manifest>
  <default revision="scarthgap" remote="yocto" sync-j="4"/>

  <remote name="yocto" fetch="https://git.yoctoproject.org/"/>
  <remote name="oe" fetch="https://github.com/openembedded/"/>
  <remote name="github" fetch="https://github.com/"/>

  <!-- Poky -->
  <project name="poky" path="sources/poky" remote="yocto" revision="scarthgap"/>

  <!-- OpenEmbedded -->
  <project name="meta-openembedded" path="sources/meta-openembedded" remote="oe" revision="scarthgap"/>

  <!-- Auton custom layer -->
  <project name="GauravAgarwalGarg/MyYoctoPlayground" path="sources/meta-auton-repo" remote="github" revision="main">
    <linkfile src="meta-auton" dest="sources/meta-auton"/>
  </project>
</manifest>
